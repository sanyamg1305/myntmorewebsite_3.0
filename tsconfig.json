{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "lib": ["DOM", "ESNext"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["main.ts"]
}
